import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner ac=new Scanner(System.in);
      int n=ac.nextInt();
      int[]arr=new int[n];
      for(int i=0;i<n;i++)
      {
        arr[i]=ac.nextInt();
        if(arr[i]>0)
        {
          System.out.println("positive");
        }
        else
        {
          System.out.println("negative");
        }
      }
      
    }
}
