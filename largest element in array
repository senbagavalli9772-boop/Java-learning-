import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner ac=new Scanner(System.in);
      int n=ac.nextInt();
      int[]arr=new int[n];
      for(int i=0;i<n;i++)
      {
        arr[i]=ac.nextInt();
      }
      int lar=arr[0];
      for(int i=1;i<n;i++)
      {
        if(arr[i]>lar){
          lar=arr[i];
        }
      }
      System.out.println(lar);
    }
}
