import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner ac=new Scanner(System.in);
      int n=ac.nextInt();
      int[]arr=new int[n];
      int sum=0;
      for(int i=0;i<n;i++)
      {
        arr[i]=ac.nextInt();
      }
      for(int i=0;i<n;i++)
          sum=sum+arr[i];
      {
        System.out.println("sum of element:" +sum);
      }
    }
}
