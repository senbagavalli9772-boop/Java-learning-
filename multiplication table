import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int n;
        Scanner ac = new Scanner(System.in);
        n = ac.nextInt();
        for(int i = 1; i <= 10; i++)
        {
            System.out.println(i + "*" + n + "=" + (i*n));
        }
    }
}
