import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int a,b,c;
        Scanner ac=new Scanner(System.in);
        a=ac.nextInt();
        b=ac.nextInt();
        c=ac.nextInt();
        if(a>b&&a>c)
        {
            System.out.println("4");
        }
        else if(b>a&&b>c)
        {
            System.out.println("8");
        }
        else
            System.out.println("5");
    }
}
